# Database
DATABASE_URL=postgresql+asyncpg://authuser:authpass@localhost:5432/auth_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=change-me-in-production-must-be-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth — GitHub (Phase 2)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8001/oauth/github/callback

# OAuth — Google (Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/oauth/google/callback

# Email (Phase 4)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@yourdomain.com

# App
APP_URL=http://localhost:8001
ENVIRONMENT=development
# Space-separated list of allowed origins, e.g. https://app.example.com https://admin.example.com
ALLOWED_ORIGINS=*

# Rate limiting (Phase 5)
# Override with redis://localhost:6379 in production to share limits across replicas
RATE_LIMIT_STORAGE_URL=memory://
